                            <TextBlock Text="{Binding Converter={StaticResource UpperCase}, Path=Game.Title}" FontSize="45" FontFamily="LAUNCHBOX_THEME_FOLDER/Fonts/Poppins-Black.ttf#Poppins Black" Foreground="#f8f8f8" TextWrapping="Wrap">
