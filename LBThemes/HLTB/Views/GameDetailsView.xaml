                                                                        <DataTemplate>
                                                                            <Border Background="#AA000000" Height="48" Width="48" BorderBrush="#AAFFFFFF" BorderThickness="2">
                                                                                <TextBlock Text="{Binding RelativeSource={RelativeSource Self}, Path=DataContext, StringFormat='{}+ {0}'}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" />
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </panel:CondensedPanel.LastItemTemplate>
                                                                </panel:CondensedPanel>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Button Height="48" Width="48" FocusVisualStyle="{x:Null}" Cursor="Hand" Command="{Binding ClickCommand}" ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0">
                                                                    <Button.Template>
                                                                        <ControlTemplate TargetType="{x:Type Button}">
                                                                            <Border x:Name="Border" Background="#AA000000" BorderBrush="#AAFFFFFF" BorderThickness="2">
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <DataTrigger Binding="{Binding HasEarned}" Value="True">
                                                                                    <Setter TargetName="Border" Property="BorderBrush" Value="#FFD700"/>
                                                                                </DataTrigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Button.Template>
                                                                    <Button.ToolTip>
                                                                        <ToolTip Placement="Bottom" VerticalOffset="10">
                                                                            <DockPanel Margin="10">
                                                                                <Border DockPanel.Dock="Left" Height="80" Width="80" BorderBrush="#AAFFFFFF" BorderThickness="1">
                                                                                    <Image Stretch="Uniform" StretchDirection="Both" Source="{Binding Image}"/>
                                                                                </Border>
                                                                                <Grid Margin="6,0,0,0" MaxWidth="320" >
                                                                                    <Grid.RowDefinitions>
                                                                                        <RowDefinition Height="Auto"/>
                                                                                        <RowDefinition Height="*"/>
                                                                                        <RowDefinition Height="Auto"/>
                                                                                    </Grid.RowDefinitions>
                                                                                    <TextBlock Margin="0,3" Text="{Binding Name}" Foreground="#E6E6E6" FontWeight="Bold" />
                                                                                    <TextBlock Grid.Row="1" Margin="0" Text="{Binding Description}" Foreground="#D6D6D6" TextWrapping="Wrap"/>
