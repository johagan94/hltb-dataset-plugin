                                                                    <DataTrigger Binding="{Binding ElementName=ListViewSteamAchievements, Path=Opacity}" Value="0">
                                                                        <Setter Property="ItemsSource" Value="{x:Null}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding ElementName=UserControl, Converter={StaticResource IsLessThan}, ConverterParameter='650', Path=ActualWidth}" Value="True">
                                                                        <Setter Property="ItemsSource" Value="{x:Null}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsLoaded}" Value="True">
