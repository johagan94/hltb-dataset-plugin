                                                <RadioButton x:Name="RetroAchievementsButton" GroupName="RetroAchievementsGroup" Margin="0,0,0,0" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0">
