                                                                                        <TextBlock.Style>
                                                                                            <Style TargetType="{x:Type TextBlock}">
                                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                                <Style.Triggers>
                                                                                                    <DataTrigger Binding="{Binding HasEarned}" Value="True">
                                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                                    </DataTrigger>
                                                                                                </Style.Triggers>
                                                                                            </Style>
                                                                                        </TextBlock.Style>
                                                                                    </TextBlock>
                                                                                </Grid>
                                                                            </DockPanel>
                                                                        </ToolTip>
                                                                    </Button.ToolTip>
                                                                    <Grid>
                                                                        <Image Stretch="Uniform" StretchDirection="Both" Source="{Binding Image}"/>
                                                                        <Rectangle Fill="#25FFFFFF" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
