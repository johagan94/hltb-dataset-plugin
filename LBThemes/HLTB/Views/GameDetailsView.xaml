<UserControl x:Name="UserControl" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="clr-namespace:Unbroken.LaunchBox.Windows.Desktop.Controls;assembly=LaunchBox"
    xmlns:system="clr-namespace:System;assembly=mscorlib"
    xmlns:panel="clr-namespace:Unbroken.LaunchBox.Windows.Controls;assembly=Unbroken.LaunchBox.Windows"
    xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
    xmlns:behaviors="clr-namespace:Unbroken.LaunchBox.Windows.Behaviors;assembly=Unbroken.LaunchBox.Windows"
    xmlns:converter="clr-namespace:Unbroken.LaunchBox.Windows.Converters;assembly=Unbroken.LaunchBox.Windows"
    xmlns:cmd="clr-namespace:Unbroken.LaunchBox.Windows.Desktop.Commands;assembly=LaunchBox"
    xmlns:coverFlow="clr-namespace:Unbroken.LaunchBox.Windows.Controls.CoverFlow;assembly=Unbroken.LaunchBox.Windows"
    xmlns:win="clr-namespace:Unbroken.LaunchBox.Windows;assembly=Unbroken.LaunchBox.Windows"
    xmlns:cal="http://www.caliburnproject.org"
    xmlns:hltb="clr-namespace:HltbDatasetPlugin;assembly=HLTB"
    mc:Ignorable="d"
    d:DesignHeight="300"
    d:DesignWidth="300"
    Focusable="False"
    FontFamily="{Binding LargeFontFamily}"
    FontSize="{Binding LargeFontSize}"
    FontWeight="{Binding LargeFontWeight}"
    FontStyle="{Binding LargeFontWeight}">
    <UserControl.Resources>
        <system:Double x:Key="WindowMinWidth">430</system:Double>
        <system:Double x:Key="WindowMinHeight">640</system:Double>
        <converter:AreEqualConverter x:Key="AreEqual" />
        <converter:ItemAtIndexConverter x:Key="ItemAtIndex"/>
        <converter:ToUpperConverter x:Key="UpperCase" />
        <hltb:HltbFieldConverter x:Key="HltbField" />
        <hltb:HltbHasDataConverter x:Key="HltbHasData" />
        <cmd:ViewImageFullscreenCommand x:Key="ViewImageFullscreenCommand" CanAlwaysExecute="True" />
        <cmd:PopOutGameDetailsCommand x:Key="PopOutWindow" PopOutSize="1920,1032" />
        <win:BindingProxy x:Key="IconVisibility"  Data="{Binding IconVisibility}"/>
        <converter:StringReplaceConverter x:Key="RemoveColon" SearchPattern=":" Replacement="" />
        <converter:MultiplyByConverter x:Key="Multiply"/>
        <converter:IsLessThanOrEqualToConverter x:Key="IsLessThan" />
        <converter:IsGreaterThanOrEqualToConverter x:Key="IsGreaterThan" />
        <converter:ScaleWithResolutionConverter x:Key="ScaleConverter" SourceResolutionHeight="1440" SourceResolutionWidth="2560"/>
        <cmd:WebLinkCommand x:Key="DbLinkCommand" Mask="https://gamesdb.launchbox-app.com/games/dbid/{0}"/>

        <!-- THEME COLORS -->
        <SolidColorBrush x:Key="BackgroundColor" Color="#1F2027"/>
        <SolidColorBrush x:Key="DarkBackground" Color="#2A2B34" />
        <SolidColorBrush x:Key="DarkerBackground" Color="#111115" />
        <SolidColorBrush x:Key="DarkForeground" Color="#6D6D6D"/>
        <SolidColorBrush x:Key="LightForeground" Color="#EDEDED"/>

        <Style x:Key="FocusVisualStyle">
            <Setter Property="Control.Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Rectangle StrokeThickness="1" Stroke="{Binding ForegroundBrush}" SnapsToDevicePixels="true" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="{x:Type ToolTip}" TargetType="ToolTip">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="HasDropShadow" Value="False"/>
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontFamily" Value="LAUNCHBOX_THEME_FOLDER/Fonts/Poppins-Regular.ttf#Poppins" />
            <Setter Property="Foreground" Value="#E1E1E1"/>
            <Setter Property="Background" Value="#00000000"/>
            <Setter Property="BorderBrush" Value="#00000000"/>
            <Setter Property="AllowDrop" Value="True"/>
            <Setter Property="Placement" Value="Center"/>
            <Setter Property="StaysOpen" Value="True"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{StaticResource DarkerBackground}" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5" Margin="10 5 10 5" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


    </UserControl.Resources>
    <Grid Margin="-7,0,0,0">
        <Grid Margin="0 0 0 0" Background="#E01f2027">

            <!-- SCROLLBAR -->
            <ScrollViewer VerticalScrollBarVisibility="Visible">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Game.Title}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>

                <!-- TOP BORDER IMAGE & ALL FALLBACKS -->
                <Grid Margin="0,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition MinHeight="250" MaxHeight="450" Height="{Binding Converter={StaticResource Multiply}, ConverterParameter='0.5', ElementName=UserControl, Path=ActualWidth}" />
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.OpacityMask>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#BB000000" Offset="0.0"/>
                                <GradientStop Color="#BB000000" Offset="0.7"/>
                                <GradientStop Color="#00000000" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Grid.OpacityMask>
                        <Grid RenderTransformOrigin="0.5,0.5">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoaded}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard Name="LogoBgAnimation">
                                                        <DoubleAnimation Storyboard.TargetProperty="(Grid.RenderTransform).(ScaleTransform.ScaleX)" BeginTime="0:0:0.35" Duration="0:0:1" From="1.2" To="1.0">
                                                            <DoubleAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetProperty="(Grid.RenderTransform).(ScaleTransform.ScaleY)" BeginTime="0:0:0.35" Duration="0:0:1" From="1.2" To="1.0">
                                                            <DoubleAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsLoaded}" Value="False">
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Opacity" Value="0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <coverFlow:FlowImage x:Name="Background" Margin="0,0,0,0" DataContext="{Binding Game}" ImageType="Steam Screenshot; Epic Games Screenshot; GOG Screenshot; Amazon Screenshot; Origin Screenshot; Backgrounds; Screenshot - Gameplay" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality" VerticalAlignment="Top" />
                        </Grid>

                    </Grid>

                    <!-- TOP BORDER OVERLAY -->
                    <Image Source="LAUNCHBOX_THEME_FOLDER/Images/Overlay.png" Stretch="UniformToFill" />


                    <Grid MaxWidth="1200" Margin="25,0" HorizontalAlignment="Stretch" Background="Transparent">

                        <!-- POP-OUT BUTTON -->
                        <Button Command="{StaticResource PopOutWindow}" TabIndex="1" Foreground="White" Margin="0 10 0 0" Width="35" Height="35" HorizontalAlignment="Left" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" FocusVisualStyle="{StaticResource FocusVisualStyle}" ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0">
                            <Button.ToolTip>
                                <ToolTip VerticalOffset="35">
                                    <TextBlock Text="{Binding PopOutWindow}" />
                                </ToolTip>
                            </Button.ToolTip>
                            <Grid Width="35" Height="35" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Viewbox Name="PopOutIcon" Stretch="Uniform" StretchDirection="Both" Height="20" Width="20" Opacity="1.0" Margin="-4,-2,0,0" IsHitTestVisible="False">
                                    <Grid>
                                        <Path Fill="White" Data="m577.92 70v-3.9219l-1.1211-2.2383-1.1211-1.6797-2.8008-3.3594-4.4805-3.3594-1.6797-1.1211-2.2383-1.1211h-129.92c-8 0-15.395 4.2695-19.398 11.199-4 6.9336-4 15.473 0 22.402 4.0039 6.9297 11.398 11.199 19.398 11.199h67.203l-201.04 199.36c-5.6992 5.7031-7.9258 14.012-5.8398 21.801 2.0859 7.7891 8.1719 13.875 15.961 15.961 7.7891 2.0859 16.098-0.14062 21.801-5.8398l201.04-201.04v67.203c0 8 4.2695 15.395 11.199 19.398 6.9336 4 15.469 4 22.402 0 6.9297-4.0039 11.199-11.398 11.199-19.398v-121.52c-0.070313-1.3242-0.25781-2.6328-0.55859-3.9219z"/>
                                        <Path Fill="White" Data="m188.72 508.48h265.44c17.824 0 34.914-7.082 47.516-19.684 12.605-12.602 19.684-29.695 19.684-47.516v-158.48c0-8.0039-4.2695-15.398-11.199-19.398-6.9297-4.0039-15.469-4.0039-22.398 0-6.9336 4-11.203 11.395-11.203 19.398v158.48c0 5.9414-2.3594 11.637-6.5586 15.84-4.2031 4.1992-9.8984 6.5586-15.84 6.5586h-265.44c-5.9414 0-11.637-2.3594-15.84-6.5586-4.1992-4.2031-6.5586-9.8984-6.5586-15.84v-265.44c0-5.9414 2.3594-11.637 6.5586-15.84 4.2031-4.1992 9.8984-6.5586 15.84-6.5586h158.48c8.0039 0 15.398-4.2695 19.398-11.203 4.0039-6.9297 4.0039-15.469 0-22.398-4-6.9297-11.395-11.199-19.398-11.199h-158.48c-17.82 0-34.914 7.0781-47.516 19.684-12.602 12.602-19.684 29.691-19.684 47.516v265.44c0 17.82 7.082 34.914 19.684 47.516s29.695 19.684 47.516 19.684z"/>
                                    </Grid>
                                </Viewbox>
                            </Grid>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type Button}">
                                                <Border Name="Border" BorderThickness="0" Background="#00787878" CornerRadius="5" Opacity="0.5">
                                                    <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Top" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger SourceName="Border" Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Opacity" Value="0.9" />
                                                        <Setter TargetName="Border" Property="Background" Value="#70787878" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsInWindow}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- BADGES -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0 15 0 0" Opacity="0.6">

                            <StackPanel Margin="10,0,0,0" Orientation="Horizontal">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding ElementName=GamePad, Path=HasBadge}" Value="False"/>
                                                    <Condition Binding="{Binding ElementName=Keyboard, Path=HasBadge}" Value="False"/>
                                                    <Condition Binding="{Binding ElementName=Mouse, Path=HasBadge}" Value="False"/>
                                                    <Condition Binding="{Binding ElementName=Joystick, Path=HasBadge}" Value="False"/>
                                                    <Condition Binding="{Binding ElementName=LightGun, Path=HasBadge}" Value="False"/>
                                                    <Condition Binding="{Binding ElementName=Trackball, Path=HasBadge}" Value="False"/>
                                                    <Condition Binding="{Binding ElementName=WheelYoke, Path=HasBadge}" Value="False"/>
                                                    <Condition Binding="{Binding ElementName=Motion, Path=HasBadge}" Value="False"/>
                                                    <Condition Binding="{Binding ElementName=Rhythm, Path=HasBadge}" Value="False"/>
                                                    <Condition Binding="{Binding ElementName=Vr, Path=HasBadge}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <coverFlow:FlowBadge x:Name="GamePad" BadgeName="GamepadSupport" DataContext="{Binding Game}" Height="24" Width="24" Margin="10,0,0,0" ToolTipService.VerticalOffset="35" ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0">
                                    <coverFlow:FlowBadge.Style>
                                        <Style TargetType="coverFlow:FlowBadge">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=GamePad, Path=HasBadge}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </coverFlow:FlowBadge.Style>
                                </coverFlow:FlowBadge>
                                <coverFlow:FlowBadge x:Name="Keyboard" BadgeName="KeyboardSupport" DataContext="{Binding Game}" Height="24" Width="24" Margin="10,0,0,0" ToolTipService.VerticalOffset="35" ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0">
                                    <coverFlow:FlowBadge.Style>
                                        <Style TargetType="coverFlow:FlowBadge">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=Keyboard, Path=HasBadge}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </coverFlow:FlowBadge.Style>
                                </coverFlow:FlowBadge>
                                <coverFlow:FlowBadge x:Name="Mouse" BadgeName="MouseSupport" DataContext="{Binding Game}" Height="24" Width="24" Margin="10,0,0,0" ToolTipService.VerticalOffset="35" ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0">
                                    <coverFlow:FlowBadge.Style>
                                        <Style TargetType="coverFlow:FlowBadge">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=Mouse, Path=HasBadge}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </coverFlow:FlowBadge.Style>
                                </coverFlow:FlowBadge>
                                <coverFlow:FlowBadge x:Name="Joystick" BadgeName="JoystickSupport" DataContext="{Binding Game}" Height="24" Width="24" Margin="10,0,0,0" ToolTipService.VerticalOffset="35" ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0">
                                    <coverFlow:FlowBadge.Style>
                                        <Style TargetType="coverFlow:FlowBadge">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=Joystick, Path=HasBadge}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </coverFlow:FlowBadge.Style>
                                </coverFlow:FlowBadge>
                                <coverFlow:FlowBadge x:Name="LightGun" BadgeName="LightGunSupport" DataContext="{Binding Game}" Height="24" Width="24" Margin="10,0,0,0" ToolTipService.VerticalOffset="35" ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0">
                                    <coverFlow:FlowBadge.Style>
                                        <Style TargetType="coverFlow:FlowBadge">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=LightGun, Path=HasBadge}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </coverFlow:FlowBadge.Style>
                                </coverFlow:FlowBadge>
                                <coverFlow:FlowBadge x:Name="Paddle" BadgeName="PaddleSupport" DataContext="{Binding Game}" Height="24" Width="24" Margin="10,0,0,0" ToolTipService.VerticalOffset="35" ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0">
                                    <coverFlow:FlowBadge.Style>
                                        <Style TargetType="coverFlow:FlowBadge">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=Paddle, Path=HasBadge}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </coverFlow:FlowBadge.Style>
                                </coverFlow:FlowBadge>
                                <coverFlow:FlowBadge x:Name="Trackball" BadgeName="TrackballSupport" DataContext="{Binding Game}" Height="24" Width="24" Margin="10,0,0,0" ToolTipService.VerticalOffset="35" ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0">
                                    <coverFlow:FlowBadge.Style>
                                        <Style TargetType="coverFlow:FlowBadge">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=Trackball, Path=HasBadge}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </coverFlow:FlowBadge.Style>
                                </coverFlow:FlowBadge>
                                <coverFlow:FlowBadge x:Name="WheelYoke" BadgeName="WheelYokeSupport" DataContext="{Binding Game}" Height="24" Width="24" Margin="10,0,0,0" ToolTipService.VerticalOffset="35" ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0">
                                    <coverFlow:FlowBadge.Style>
                                        <Style TargetType="coverFlow:FlowBadge">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=WheelYoke, Path=HasBadge}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </coverFlow:FlowBadge.Style>
                                </coverFlow:FlowBadge>
                                <coverFlow:FlowBadge x:Name="Motion" BadgeName="MotionSupport" DataContext="{Binding Game}" Height="24" Width="24" Margin="10,0,0,0" ToolTipService.VerticalOffset="35" ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0">
                                    <coverFlow:FlowBadge.Style>
                                        <Style TargetType="coverFlow:FlowBadge">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=Motion, Path=HasBadge}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </coverFlow:FlowBadge.Style>
                                </coverFlow:FlowBadge>
                                <coverFlow:FlowBadge x:Name="Rhythm" BadgeName="RhythmSupport" DataContext="{Binding Game}" Height="24" Width="24" Margin="10,0,0,0" ToolTipService.VerticalOffset="35" ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0">
                                    <coverFlow:FlowBadge.Style>
                                        <Style TargetType="coverFlow:FlowBadge">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=Rhythm, Path=HasBadge}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </coverFlow:FlowBadge.Style>
                                </coverFlow:FlowBadge>
                                <coverFlow:FlowBadge x:Name="Vr" BadgeName="VrSupport" DataContext="{Binding Game}" Height="24" Width="24" Margin="10,0,0,0" ToolTipService.VerticalOffset="35" ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0">
                                    <coverFlow:FlowBadge.Style>
                                        <Style TargetType="coverFlow:FlowBadge">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=Vr, Path=HasBadge}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </coverFlow:FlowBadge.Style>
                                </coverFlow:FlowBadge>

                            </StackPanel>

                            <StackPanel Margin="10,0,0,0" Orientation="Horizontal">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding ElementName=Steam, Path=HasBadge}" Value="False"/>
                                                    <Condition Binding="{Binding ElementName=Origin, Path=HasBadge}" Value="False"/>
                                                    <Condition Binding="{Binding ElementName=EA, Path=HasBadge}" Value="False"/>
                                                    <Condition Binding="{Binding ElementName=EpicGames, Path=HasBadge}" Value="False"/>
                                                    <Condition Binding="{Binding ElementName=GOG, Path=HasBadge}" Value="False"/>
                                                    <Condition Binding="{Binding ElementName=Amazon, Path=HasBadge}" Value="False"/>
                                                    <Condition Binding="{Binding ElementName=Uplay, Path=HasBadge}" Value="False"/>
                                                    <Condition Binding="{Binding ElementName=Xbox, Path=HasBadge}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <coverFlow:FlowBadge x:Name="SteamBadge" BadgeName="Steam" DataContext="{Binding Game}" Height="24" Width="24" Margin="10,0,0,0" ToolTipService.VerticalOffset="35" ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0">
                                    <coverFlow:FlowBadge.Style>
                                        <Style TargetType="coverFlow:FlowBadge">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=SteamBadge, Path=HasBadge}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </coverFlow:FlowBadge.Style>
                                </coverFlow:FlowBadge>
                                <coverFlow:FlowBadge x:Name="OriginBadge" BadgeName="Origin" DataContext="{Binding Game}" Height="24" Width="24" Margin="10,0,0,0" ToolTipService.VerticalOffset="35" ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0">
                                    <coverFlow:FlowBadge.Style>
                                        <Style TargetType="coverFlow:FlowBadge">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=OriginBadge, Path=HasBadge}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </coverFlow:FlowBadge.Style>
                                </coverFlow:FlowBadge>
                                <coverFlow:FlowBadge x:Name="EABadge" BadgeName="EA" DataContext="{Binding Game}" Height="24" Width="24" Margin="10,0,0,0" ToolTipService.VerticalOffset="35" ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0">
                                    <coverFlow:FlowBadge.Style>
                                        <Style TargetType="coverFlow:FlowBadge">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=EABadge, Path=HasBadge}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </coverFlow:FlowBadge.Style>
                                </coverFlow:FlowBadge>
                                <coverFlow:FlowBadge x:Name="EpicGamesBadge" BadgeName="EpicGames" DataContext="{Binding Game}" Height="24" Width="24" Margin="10,0,0,0" ToolTipService.VerticalOffset="35" ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0">
                                    <coverFlow:FlowBadge.Style>
                                        <Style TargetType="coverFlow:FlowBadge">
