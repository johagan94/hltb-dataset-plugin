                                                            <Style TargetType="ItemsControl">
                                                                <Setter Property="ItemsSource" Value="{Binding Achievements.Steam}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ElementName=UserControl, Converter={StaticResource IsLessThan}, ConverterParameter='650', Path=ActualWidth}" Value="False">
                                                                        <Setter Property="ItemsSource" Value="{x:Null}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ItemsControl.Style>
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <panel:CondensedPanel ItemSize="48,48" MinimumSpacing="5">
