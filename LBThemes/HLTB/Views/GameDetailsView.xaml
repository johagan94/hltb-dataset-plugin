                                                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                                            </DataTrigger>
                                                                                                            <DataTrigger Binding="{Binding Game.InstallState}" Value="Updating">
                                                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                                            </DataTrigger>
                                                                                                            <DataTrigger Binding="{Binding Game.InstallState}" Value="InstallPaused">
                                                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                                            </DataTrigger>
                                                                                                            <DataTrigger Binding="{Binding Game.InstallState}" Value="UpdatePaused">
                                                                                                                <Setter Property="Visibility" Value="Collapsed"/>
