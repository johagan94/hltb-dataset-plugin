                                                            </Style.Triggers>
                                                        </Style>
                                                    </RadioButton.Style>
                                                </RadioButton>
                                            </StackPanel>
                                        </Border>

                                        <!-- STEAM ACHIEVEMENTS -->
                                        <Border Margin="0,25,0,0" Background="{StaticResource DarkBackground}" CornerRadius="25">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Achievements.Steam.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Margin="35,25,35,10">

                                                <TextBlock FontFamily="{Binding TitleFontFamily}" Text="{Binding Achievements.Steam.Count, Mode=OneWay, StringFormat='{}STEAM ACHIEVEMENTS ({0})'}" FontSize="{Binding TitleFontSize}" TextTrimming="CharacterEllipsis" HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="#6e7b80"/>

                                                <StackPanel Orientation="Vertical" Margin="6,15">
                                                    <StackPanel.Style>
                                                        <Style TargetType="{x:Type StackPanel}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ElementName=UserControl, Converter={StaticResource IsLessThan}, ConverterParameter='650', Path=ActualWidth}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <ProgressBar Margin="0,0,0,9" Height="10" Minimum="0" Maximum="{Binding Achievements.Steam.Count, Mode=OneWay}"
                                                        Value="{Binding Achievements.SteamEarned.Count, Mode=OneWay}" ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0">
                                                        <ProgressBar.ToolTip>
                                                            <ToolTip VerticalOffset="-30">
                                                                <TextBlock Text="{Binding Achievements.SteamProgressLabel}" />
                                                            </ToolTip>
                                                        </ProgressBar.ToolTip>
