                                                                                                </Setter>
                                                                                                <Style.Triggers>
                                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                                        <Setter Property="Background" Value="{StaticResource DarkerBackground}"/>
                                                                                                    </Trigger>
