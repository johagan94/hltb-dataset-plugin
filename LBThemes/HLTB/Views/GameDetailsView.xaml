                                                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Stretch" TextAlignment="Center" Foreground="{Binding ForegroundBrush}" FontSize="{Binding LargeFontSize}"
                                                        Text="{Binding LoadingLabel}" Visibility="{Binding RecommendedGamesLoadingVisibility}"/>
                                                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Stretch" TextAlignment="Center" Foreground="{Binding ForegroundBrush}" FontSize="{Binding LargeFontSize}" Text="{Binding NoGamesFoundLabel}" Visibility="{Binding RecommendedGamesEmptyVisibility}"/>
                                                    <ListBox SelectionMode="Single" HorizontalContentAlignment="Stretch" HorizontalAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Background="Transparent" BorderThickness="0">
                                                        <i:Interaction.Behaviors>
                                                            <behaviors:BubbleWheelEventListBoxBehavior />
                                                        </i:Interaction.Behaviors>
                                                        <ListBox.ItemContainerStyle>
                                                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
