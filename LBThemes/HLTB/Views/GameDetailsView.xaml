                                        <TabControl SelectedIndex="-1" Margin="0,5,0,0" Background="Transparent" BorderThickness="0" BorderBrush="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" cal:Message.Attach="[Event SelectionChanged] = [Action OnTabSelectionChanged($source, $eventArgs)]">
