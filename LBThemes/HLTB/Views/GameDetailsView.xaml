                                                <!-- PLAY BUTTON -->
                                                <Grid MaxHeight="75" Height="{Binding Converter={StaticResource Multiply}, ConverterParameter='0.12', ElementName=UserControl, Path=ActualWidth}" HorizontalAlignment="Stretch">
