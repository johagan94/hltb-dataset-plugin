                                                            <Setter TargetName="Text" Property="Foreground" Value="#EAEAEA" />
                                                            <Setter TargetName="Text" Property="Opacity" Value="0.6" />
                                                            <Setter TargetName="Border" Property="Background" Value="Transparent"/>
                                                        </Trigger>
