<UserControl x:Name="UserControl" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="clr-namespace:Unbroken.LaunchBox.Windows.Desktop.Controls;assembly=LaunchBox"
    xmlns:system="clr-namespace:System;assembly=mscorlib"
    xmlns:panel="clr-namespace:Unbroken.LaunchBox.Windows.Controls;assembly=Unbroken.LaunchBox.Windows"
    xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
    xmlns:behaviors="clr-namespace:Unbroken.LaunchBox.Windows.Behaviors;assembly=Unbroken.LaunchBox.Windows"
    xmlns:converter="clr-namespace:Unbroken.LaunchBox.Windows.Converters;assembly=Unbroken.LaunchBox.Windows"
    xmlns:cmd="clr-namespace:Unbroken.LaunchBox.Windows.Desktop.Commands;assembly=LaunchBox"
    xmlns:coverFlow="clr-namespace:Unbroken.LaunchBox.Windows.Controls.CoverFlow;assembly=Unbroken.LaunchBox.Windows"
    xmlns:win="clr-namespace:Unbroken.LaunchBox.Windows;assembly=Unbroken.LaunchBox.Windows"
    xmlns:cal="http://www.caliburnproject.org"
    mc:Ignorable="d" 
    d:DesignHeight="300"
    d:DesignWidth="300"
    Focusable="False"
    FontFamily="{Binding LargeFontFamily}"
    FontSize="{Binding LargeFontSize}"
    FontWeight="{Binding LargeFontWeight}"
    FontStyle="{Binding LargeFontWeight}">
    <UserControl.Resources>
        <system:Double x:Key="WindowMinWidth">430</system:Double>
        <system:Double x:Key="WindowMinHeight">640</system:Double>
        <converter:AreEqualConverter x:Key="AreEqual" />
        <converter:ItemAtIndexConverter x:Key="ItemAtIndex"/>
        <converter:ToUpperConverter x:Key="UpperCase" />
        <cmd:ViewImageFullscreenCommand x:Key="ViewImageFullscreenCommand" CanAlwaysExecute="True" />
        <cmd:PopOutGameDetailsCommand x:Key="PopOutWindow" PopOutSize="1920,1032" />
        <win:BindingProxy x:Key="IconVisibility"  Data="{Binding IconVisibility}"/>
        <converter:StringReplaceConverter x:Key="RemoveColon" SearchPattern=":" Replacement="" />
        <converter:MultiplyByConverter x:Key="Multiply"/>
        <converter:IsLessThanOrEqualToConverter x:Key="IsLessThan" />
        <converter:IsGreaterThanOrEqualToConverter x:Key="IsGreaterThan" />
        <converter:ScaleWithResolutionConverter x:Key="ScaleConverter" SourceResolutionHeight="1440" SourceResolutionWidth="2560"/>
        <cmd:WebLinkCommand x:Key="DbLinkCommand" Mask="https://gamesdb.launchbox-app.com/games/dbid/{0}"/>

        <!-- THEME COLORS -->
        <SolidColorBrush x:Key="BackgroundColor" Color="#1F2027"/>
        <SolidColorBrush x:Key="DarkBackground" Color="#2A2B34" />
        <SolidColorBrush x:Key="DarkerBackground" Color="#111115" />
        <SolidColorBrush x:Key="DarkForeground" Color="#6D6D6D"/>
        <SolidColorBrush x:Key="LightForeground" Color="#EDEDED"/>
        <Style x:Key="FocusVisualStyle">
            <Setter Property="Control.Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Border Background="Transparent" BorderThickness="0" BorderBrush="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="{x:Type ToolTip}" TargetType="ToolTip">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="HasDropShadow" Value="False"/>
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontFamily" Value="LAUNCHBOX_THEME_FOLDER/Fonts/Poppins-Regular.ttf#Poppins" />
            <Setter Property="Foreground" Value="#E1E1E1"/>
            <Setter Property="Background" Value="#00000000"/>
            <Setter Property="BorderBrush" Value="#00000000"/>
            <Setter Property="AllowDrop" Value="True"/>
            <Setter Property="Placement" Value="Center"/>
            <Setter Property="StaysOpen" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{StaticResource DarkerBackground}" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5" Margin="10 5 10 5" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>
    <Grid Margin="-7,0,0,0">
        <Grid Background="#E01f2027">
            <!-- SCROLLBAR -->
            <ScrollViewer Margin="0" Padding="0" VerticalScrollBarVisibility="Auto">

                <!-- TOP BORDER IMAGE & ALL FALLBACKS -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition MinHeight="250" MaxHeight="450" Height="{Binding Converter={StaticResource Multiply}, ConverterParameter='0.5', ElementName=UserControl, Path=ActualWidth}" />
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.OpacityMask>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#000000" Offset="0.0"/>
                                <GradientStop Color="#000000" Offset="0.7"/>
                                <GradientStop Color="#00000000" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Grid.OpacityMask>
                        <Grid RenderTransformOrigin="0.5,0.5">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Opacity" Value="0"/>
                                    <Style.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" Duration="0:0:1" BeginTime="0:0:0.2" To="1" />
                                                    <DoubleAnimation Storyboard.TargetProperty="(Grid.RenderTransform).(ScaleTransform.ScaleX)" BeginTime="0:0:0.2" Duration="0:0:1" To="1.0">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="(Grid.RenderTransform).(ScaleTransform.ScaleY)" BeginTime="0:0:0.2" Duration="0:0:1" To="1.0">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <coverFlow:FlowImage ImageType="Backgrounds" Stretch="UniformToFill" Opacity="1.0" DataContext="{Binding Platform}" RenderOptions.BitmapScalingMode="HighQuality" VerticalAlignment="Top" CreateFallbackImage="True" RenderOptions.CachingHint="Cache">
                                <coverFlow:FlowImage.CacheMode>
                                    <BitmapCache/>
                                </coverFlow:FlowImage.CacheMode>
                            </coverFlow:FlowImage>
                        </Grid>

                    </Grid>

                    <!-- TOP BORDER OVERLAY -->
                    <Image Source="LAUNCHBOX_THEME_FOLDER/Images/Overlay.png" Stretch="UniformToFill" />


                    <Grid MaxWidth="1200" Margin="25,0" HorizontalAlignment="Stretch" Background="Transparent">

                        <!-- POP-OUT BUTTON -->
                        <Button Command="{StaticResource PopOutWindow}" Foreground="White" Margin="0 10 0 0" Width="35" Height="35" HorizontalAlignment="Left" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" FocusVisualStyle="{StaticResource FocusVisualStyle}" ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0">
                            <Button.ToolTip>
                                <ToolTip VerticalOffset="35">
                                    <TextBlock Text="{Binding PopOutWindow}" />
                                </ToolTip>
                            </Button.ToolTip>
                            <Grid Width="35" Height="35" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Viewbox Name="PopOutIcon" Stretch="Uniform" StretchDirection="Both" Height="20" Width="20" Opacity="1.0" Margin="-4,-2,0,0" IsHitTestVisible="False">
                                    <Grid>
                                        <Path Fill="White" Data="m577.92 70v-3.9219l-1.1211-2.2383-1.1211-1.6797-2.8008-3.3594-4.4805-3.3594-1.6797-1.1211-2.2383-1.1211h-129.92c-8 0-15.395 4.2695-19.398 11.199-4 6.9336-4 15.473 0 22.402 4.0039 6.9297 11.398 11.199 19.398 11.199h67.203l-201.04 199.36c-5.6992 5.7031-7.9258 14.012-5.8398 21.801 2.0859 7.7891 8.1719 13.875 15.961 15.961 7.7891 2.0859 16.098-0.14062 21.801-5.8398l201.04-201.04v67.203c0 8 4.2695 15.395 11.199 19.398 6.9336 4 15.469 4 22.402 0 6.9297-4.0039 11.199-11.398 11.199-19.398v-121.52c-0.070313-1.3242-0.25781-2.6328-0.55859-3.9219z"/>
                                        <Path Fill="White" Data="m188.72 508.48h265.44c17.824 0 34.914-7.082 47.516-19.684 12.605-12.602 19.684-29.695 19.684-47.516v-158.48c0-8.0039-4.2695-15.398-11.199-19.398-6.9297-4.0039-15.469-4.0039-22.398 0-6.9336 4-11.203 11.395-11.203 19.398v158.48c0 5.9414-2.3594 11.637-6.5586 15.84-4.2031 4.1992-9.8984 6.5586-15.84 6.5586h-265.44c-5.9414 0-11.637-2.3594-15.84-6.5586-4.1992-4.2031-6.5586-9.8984-6.5586-15.84v-265.44c0-5.9414 2.3594-11.637 6.5586-15.84 4.2031-4.1992 9.8984-6.5586 15.84-6.5586h158.48c8.0039 0 15.398-4.2695 19.398-11.203 4.0039-6.9297 4.0039-15.469 0-22.398-4-6.9297-11.395-11.199-19.398-11.199h-158.48c-17.82 0-34.914 7.0781-47.516 19.684-12.602 12.602-19.684 29.691-19.684 47.516v265.44c0 17.82 7.082 34.914 19.684 47.516s29.695 19.684 47.516 19.684z"/>
                                    </Grid>
                                </Viewbox>
                            </Grid>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type Button}">
                                                <Border Name="Border" BorderThickness="0" Background="#00787878" CornerRadius="5" Opacity="0.5">
                                                    <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Top" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger SourceName="Border" Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Opacity" Value="0.9" />
                                                        <Setter TargetName="Border" Property="Background" Value="#70787878" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsInWindow}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- BUTTONS -->
                        <Viewbox Grid.Row="2" Grid.Column="1" VerticalAlignment="Bottom" MaxHeight="50" Height="{Binding Converter={StaticResource Multiply}, ConverterParameter='0.08', ElementName=UserControl, Path=ActualWidth}" HorizontalAlignment="Right" Margin="0,0,0,15">
                            <Button Command="{Binding EditCommand}" Width="50" Height="50" Background="Transparent" BorderThickness="0" Visibility="{Binding EditVisibility}" FocusVisualStyle="{StaticResource FocusVisualStyle}" ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0">
                                <Button.ToolTip>
                                    <ToolTip Background="Transparent" BorderThickness="0" StaysOpen="True" Placement="Center" VerticalOffset="-45">
                                        <TextBlock Text="{Binding EditLabel}" FontFamily="LAUNCHBOX_THEME_FOLDER/Fonts/Poppins-Regular.ttf#Poppins" Foreground="{StaticResource LightForeground}" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </ToolTip>
                                </Button.ToolTip>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type Button}">
                                                    <Border Name="Border" BorderThickness="0" Background="#30FFFFFF" CornerRadius="10" Opacity="0.7">
                                                        <Grid>
                                                            <Path x:Name="Edit" Width="25" Height="25" Stretch="Fill" RenderTransformOrigin="0.5,0.5" Data="F1 M 53.2929,21.2929L 54.7071,22.7071C 56.4645,24.4645 56.4645,27.3137 54.7071,29.0711L 52.2323,31.5459L 44.4541,23.7677L 46.9289,21.2929C 48.6863,19.5355 51.5355,19.5355 53.2929,21.2929 Z M 31.7262,52.052L 23.948,44.2738L 43.0399,25.182L 50.818,32.9601L 31.7262,52.052 Z M 23.2409,47.1023L 28.8977,52.7591L 21.0463,54.9537L 23.2409,47.1023 Z ">
                                                                <Path.Style>
                                                                    <Style TargetType="Path">
                                                                        <Setter Property="Fill" Value="#90FFFFFF" />
                                                                        <Setter Property="RenderTransform">
                                                                            <Setter.Value>
                                                                                <RotateTransform Angle="0" />
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </Style>
                                                                </Path.Style>
                                                            </Path>
                                                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Top" />
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger SourceName="Border" Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Border" Property="Opacity" Value="0.9" />
                                                            <Trigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="Edit" Storyboard.TargetProperty="(Path.RenderTransform).(RotateTransform.Angle)" To="-90" Duration="0:0:0.3" AccelerationRatio="0.2">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <CubicEase EasingMode="EaseIn" />
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.EnterActions>
                                                            <Trigger.ExitActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="Edit" Storyboard.TargetProperty="(Path.RenderTransform).(RotateTransform.Angle)" Duration="0:0:0.6" AccelerationRatio="0.2">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <CubicEase EasingMode="EaseOut" />
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.ExitActions>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Viewbox>
                    </Grid>

                    <!-- CLEAR LOGO & TEXT TITLE FALLBACK -->
                    <Grid RenderTransformOrigin="0.5,0.5">
                        <Grid.CacheMode>
                            <BitmapCache/>
                        </Grid.CacheMode>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.7" ScaleY="0.7"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Opacity" Value="0"/>
                                <Style.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" Duration="0:0:1" BeginTime="0:0:0.2" To="1" />
                                                <DoubleAnimation Storyboard.TargetProperty="(Grid.RenderTransform).(ScaleTransform.ScaleX)" BeginTime="0:0:0.2" Duration="0:0:1" To="1.0">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="(Grid.RenderTransform).(ScaleTransform.ScaleY)" BeginTime="0:0:0.2" Duration="0:0:1" To="1.0">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="5*"/>
                            <ColumnDefinition Width="10*"/>
                            <ColumnDefinition Width="5*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="10*"/>
                            <RowDefinition Height="20*"/>
                            <RowDefinition Height="10*"/>
                        </Grid.RowDefinitions>
                        <Image Grid.Column="1" Grid.Row="1" Source="{Binding PlatformClearLogoImage}" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5 0.5" RenderOptions.BitmapScalingMode="HighQuality" RenderOptions.CachingHint="Cache"/>
                        <Viewbox MaxWidth="1200" Height="150" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="100,0">
                            <Viewbox.Style>
                                <Style TargetType="Viewbox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PlatformClearLogoImage}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Viewbox.Style>
                            <Grid>
                                <TextBlock Text="{Binding FilterPair}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="55" TextWrapping="Wrap" FontFamily="LAUNCHBOX_THEME_FOLDER/Fonts/Poppins-Black.ttf#Poppins Black" TextAlignment="Center" />
                                <TextBlock Text="{Binding PlatformTitle}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="55" TextWrapping="Wrap" FontFamily="LAUNCHBOX_THEME_FOLDER/Fonts/Poppins-Black.ttf#Poppins Black" TextAlignment="Center" />
                            </Grid>
                        </Viewbox>
                    </Grid>

                    <Grid MaxWidth="1200" Margin="25,10,25,0" HorizontalAlignment="Stretch" Grid.Row="1">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Margin="0,0,0,10" Text="{Binding Converter={StaticResource UpperCase}, Path=PlatformTitle}" FontSize="45" FontFamily="LAUNCHBOX_THEME_FOLDER/Fonts/Poppins-Black.ttf#Poppins Black" Foreground="#f8f8f8" TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=UserControl, Converter={StaticResource IsLessThan}, ConverterParameter='640', Path=ActualWidth}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PlatformTitle}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Margin="0,0,0,10" Text="{Binding Converter={StaticResource UpperCase}, Path=PlatformTitle}" FontSize="30" FontFamily="LAUNCHBOX_THEME_FOLDER/Fonts/Poppins-Black.ttf#Poppins Black" Foreground="#f8f8f8" TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=UserControl, Converter={StaticResource IsLessThan}, ConverterParameter='640', Path=ActualWidth}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PlatformTitle}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="10*"/>
                                    <ColumnDefinition Width="315"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <!-- MEDIA PREVIEW -->
                                <Viewbox VerticalAlignment="Top" Visibility="{Binding EditVisibility}">
                                    <Viewbox.Style>
                                        <Style TargetType="Viewbox">
                                            <Setter Property="Grid.ColumnSpan" Value="1"/>
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=UserControl, Converter={StaticResource IsLessThan}, ConverterParameter='800', Path=ActualWidth}" Value="True">
                                                    <Setter Property="Grid.ColumnSpan" Value="2"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Viewbox.Style>
                                    <Border x:Name="VideoBorder" Background="{StaticResource DarkBackground}" CornerRadius="25" Height="500" Width="888">
                                        <Border.OpacityMask>
                                            <VisualBrush>
                                                <VisualBrush.Visual>
                                                    <Border Background="Black" CornerRadius="25" Height="500" Width="888"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Border.OpacityMask>
                                        <Grid>
                                            <controls:MediaPreview x:Name="MediaPreview" Height="500" HorizontalAlignment="Center" Background="Transparent" RenderOptions.CachingHint="Cache">
                                                <controls:MediaPreview.Style>
                                                    <Style TargetType="controls:MediaPreview">
                                                        <Setter Property="MediaItem" Value="{Binding ElementName=MediaList, Path=SelectedItem}"/>
                                                        <Setter Property="Opacity" Value="0"/>
                                                        <Style.Triggers>
                                                            <EventTrigger RoutedEvent="Loaded">
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" BeginTime="00:00:1.5" From="0" To="1.0" Duration="00:00:01" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </EventTrigger>
                                                            <DataTrigger Binding="{Binding ElementName=MediaList, Path=Items.Count}" Value="0">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </controls:MediaPreview.Style>
                                            </controls:MediaPreview>
                                            <TextBlock Text="{Binding NoAvailableMediaLabel}" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="LAUNCHBOX_THEME_FOLDER/Fonts/Poppins-Light.ttf#Poppins Light" Foreground="#FFFFFF" Opacity="0.5"  TextWrapping="Wrap">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ElementName=MediaList, Path=Items.Count}" Value="0">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </Viewbox>
                                <!-- PLAY BUTTONS + MAIN INFORMATION -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Margin" Value="25,0,0,0"/>
                                            <Setter Property="Grid.Row" Value="0"/>
                                            <Setter Property="Grid.Column" Value="1"/>
                                            <Setter Property="Grid.ColumnSpan" Value="1"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=UserControl, Converter={StaticResource IsLessThan}, ConverterParameter='800', Path=ActualWidth}" Value="True">
                                                    <Setter Property="Margin" Value="0,25,0,0"/>
                                                    <Setter Property="Grid.Row" Value="2"/>
                                                    <Setter Property="Grid.Column" Value="0"/>
                                                    <Setter Property="Grid.ColumnSpan" Value="2"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <Grid HorizontalAlignment="Stretch">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition>
                                                <ColumnDefinition.Style>
                                                    <Style TargetType="ColumnDefinition">
                                                        <Setter Property="Width" Value="*"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding LastPlayedGame}" Value="{x:Null}">
                                                                <Setter Property="Width" Value="Auto" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ColumnDefinition.Style>
                                            </ColumnDefinition>
                                            <ColumnDefinition>
                                                <ColumnDefinition.Style>
                                                    <Style TargetType="ColumnDefinition">
                                                        <Setter Property="Width" Value="*"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding MostPlayedGame}" Value="{x:Null}">
                                                                <Setter Property="Width" Value="Auto" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ColumnDefinition.Style>
