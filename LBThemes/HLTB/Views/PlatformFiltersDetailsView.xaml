                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Platform.Notes}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Platform.Notes}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Margin="40,25">
                                    <TextBlock Text="{Binding DescriptionLabel, Converter={StaticResource UpperCase}}" FontFamily="LAUNCHBOX_THEME_FOLDER/Fonts/Poppins-Regular.ttf#Poppins" FontSize="{Binding TitleFontSize}" HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="#6e7b80" />
                                    <TextBlock Margin="0,25,0,0" Text="{Binding Platform.Notes, Mode=OneWay}" FontFamily="LAUNCHBOX_THEME_FOLDER/Fonts/Poppins-Regular.ttf#Poppins" Foreground="{StaticResource LightForeground}" TextWrapping="Wrap"  />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,25,0,0" MinHeight="10" Background="Transparent" CornerRadius="25">

                            </Border>
                        </StackPanel>
                    </Grid>


                </Grid>
            </ScrollViewer>
        </Grid>







    </Grid>



</UserControl>