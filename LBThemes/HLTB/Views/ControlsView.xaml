                                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Polygon Points="0,0 0,13 3,13 3,0" StrokeThickness="0" Fill="{TemplateBinding Foreground}" />
                                                    <Polygon Points="6,0 6,13 9,13 9,0" StrokeThickness="0" Fill="{TemplateBinding Foreground}" />
                                                </Grid>
                                            </Grid>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <!-- Next Song Button -->
                            <Button Name="Next" ToolTip="Next Track" Content="Next" Command="{Binding NextCommand}" Grid.Row="1" Grid.Column="6" IsEnabled="{Binding NextEnabled}" Focusable="True" FocusVisualStyle="{StaticResource PlaybackFocusVisualStyle}">
