                        </StackPanel>
                        <StackPanel Grid.Row="1" Margin="0 25 0 0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom">

                            <!-- Previous Song Button -->
                            <Button Name="Previous" ToolTip="Previous Track" Content="Previous" Command="{Binding PreviousCommand}" IsEnabled="{Binding PreviousEnabled}" Focusable="True" FocusVisualStyle="{StaticResource PlaybackFocusVisualStyle}">
