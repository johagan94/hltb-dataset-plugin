<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border x:Name="Border" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="60" BorderThickness="1" CornerRadius="9">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="#242428"/>
                <Setter Property="Margin" Value="0,0,0,10"/>
                <Setter Property="BorderBrush" Value="#7046464C"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsInTray}" Value="True">
                        <Setter Property="Background" Value="#EF212226"/>
                        <Setter Property="Margin" Value="0,10,0,0"/>
                        <Setter Property="BorderBrush" Value="#46464C"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding DateRead}" Value="{x:Null}">
                        <Setter Property="Background" Value="#29292E"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Opacity" Value="0.6"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DateRead}" Value="{x:Null}">
                            <Setter Property="Opacity" Value="1.0"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid Margin="9">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.ColumnSpan="2">
                    <TextBlock Text="{Binding DateRaised, StringFormat='{}yyyy-MM-dd h:mm tt'}" Foreground="White" Opacity="0.5" HorizontalAlignment="Left" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="Dismiss" ToolTip="Dismiss" Background="Transparent" BorderThickness="0" Focusable="True" FocusVisualStyle="{x:Null}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type Button}">
                                                <Border x:Name="Border" BorderThickness="0" Background="{TemplateBinding Background}">
                                                    <TextBlock x:Name="Text" HorizontalAlignment="Center" Margin="6,0" VerticalAlignment="Center" Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#C0C0C1" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger SourceName="Border" Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Text" Property="Foreground" Value="#EFEFEF" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Image Grid.Row="1" Grid.Column="0" VerticalAlignment="Top" MaxWidth="48" Stretch="Uniform" StretchDirection="Both" Source="{Binding Icon}">
                        <Image.Style>
                            <Style TargetType="{x:Type Image}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="12,0,0,0" Text="{Binding Message}" TextWrapping="Wrap" Foreground="#BDBDBE" FontSize="14"/>
                </Grid>
                <ItemsControl Grid.Row="2" Grid.ColumnSpan="2" Margin="0,0,0,0" HorizontalAlignment="Stretch" ItemsSource="{Binding Buttons}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical" IsItemsHost="True" HorizontalAlignment="Stretch" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding Command}">
                                <TextBlock Text="{Binding Label}" FontSize="12" Foreground="#F1F1F1" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type Button}">
                                                    <Border x:Name="Border" BorderThickness="1" Background="#2E2F31" BorderBrush="#454546" CornerRadius="3" Margin="0,12,0,0">
                                                        <ContentPresenter Margin="6" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger SourceName="Border" Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Border" Property="Background" Value="#333438" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
            <Border CornerRadius="9" BorderThickness="1" BorderBrush="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#FFFFFF" IsHitTestVisible="False">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Opacity" Value="0"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding ElementName=Border, Path=IsMouseOver}" Value="True"/>
                                    <Condition Binding="{Binding IsInTray}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Opacity" Value="0.02"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>
        </Grid>
    </Border>
</UserControl>
